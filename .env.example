# NETCONF Device Credentials
# ----------------------------
# Copy this file to .env and fill in your actual values.
# .env is listed in .gitignore and will NOT be committed to the repository.
#
# Usage:
#   cp .env.example .env
#   # edit .env with real credentials
#   export $(cat .env | xargs)   # load into shell
#   python scripts/01_netconf_connect.py
#
# Alternatively, pass credentials directly as CLI arguments:
#   python scripts/01_netconf_connect.py --host 192.0.2.1 --username admin --password secret

NETCONF_HOST=192.0.2.1
NETCONF_USERNAME=netconf_user
NETCONF_PASSWORD=netconf_password
